-- Conky overlay showing the todo.txt list in the bottom-right corner
-- (Wayland output for Sway). Started by the todo-conky script.
conky.config = {
    out_to_wayland = true,
    out_to_x = false,
    alignment = 'bottom_right',
    background = true,
    border_width = 5,
    double_buffer = true,
    font = 'Ubuntu:size=8',
    gap_x = 20,
    gap_y = 20,
    minimum_height = 5,
    minimum_width = 5,
    own_window = true,
    own_window_class = 'Conky',
    own_window_colour = '2E3440',
    own_window_argb_visual = true,
    own_window_argb_value = 255,
    own_window_type = 'override',
    own_window_hints = 'below',
    draw_shades = false,
    draw_outline = false,
    draw_borders = false,
    text_buffer_size = 1024,
    update_interval = 10.0,
    use_xft = true
}

-- Every 2 minutes: list todos using the conky color config,
-- dropping the two summary lines at the end
conky.text = [[
${execpi 120 todo.sh -d ~/.todo/config-conky ls | head -n -2}
]]
