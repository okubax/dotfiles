# Show last backup times
bb-last() {
    echo "=== Last Backup Times ==="
    echo
    echo "Local snapshots:"
    for subvol in root home; do
        local latest=$(sudo find /mnt/btr_pool/.snapshots/$subvol -maxdepth 1 -name "backup_*" -type d 2>/dev/null | sort | tail -1)
        if [[ -n "$latest" ]]; then
            echo "  $subvol: $(basename "$latest")"
        else
            echo "  $subvol: None"
        fi
    done
    echo

    if mount | grep -q "$BTRFS_BACKUP_UUID"; then
        echo "External backups:"
        for subvol in root home; do
            local ext_dir="/run/media/ajibola/$BTRFS_BACKUP_UUID/btrfs_backups/$subvol"
            if [[ -d "$ext_dir" ]]; then
                local latest_parent=$(sudo find "$ext_dir" -maxdepth 1 -name "parent_*" -type d 2>/dev/null | sort | tail -1)
                local latest_incr=$(sudo find "$ext_dir" -maxdepth 1 -name "incremental_*" -type d 2>/dev/null | sort | tail -1)
                echo "  $subvol parent: $(basename "$latest_parent" 2>/dev/null || echo "None")"
                echo "  $subvol incremental: $(basename "$latest_incr" 2>/dev/null || echo "None")"
            fi
        done
    else
        echo "External drive not mounted"
    fi
}

