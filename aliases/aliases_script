# Show parent-incremental relationships (v2.2 feature)
bb-tree() {
    # Use a single sudo call to run the entire function logic
    # This avoids multiple sudo prompts and stdin issues
    sudo bash << 'EOFSCRIPT'
        BTRFS_BACKUP_UUID="98f725b9-9e2b-4b89-8345-6e0ca03657f4"

        echo "=== Backup Chain Structure ==="
        echo

        if ! mount | grep -q "$BTRFS_BACKUP_UUID"; then
            echo "External drive not mounted"
            exit 1
        fi

        for subvol in root home; do
            ext_dir="/run/media/ajibola/$BTRFS_BACKUP_UUID/btrfs_backups/$subvol"

            if [[ ! -d "$ext_dir" ]]; then
                continue
            fi

            echo "=== $subvol subvolume ==="

            # Get all parent backups
            parents_list=$(find "$ext_dir" -maxdepth 1 -name "parent_*" -type d 2>/dev/null | sort)

            if [[ -z "$parents_list" ]]; then
                echo "  (no parent backups found)"
                echo
                continue
            fi

            # Process each parent
            while IFS= read -r parent; do
                if [[ -n "$parent" ]]; then
                    parent_name=$(basename "$parent")
                    parent_date=$(echo "$parent_name" | grep -oP '\d{8}_\d{6}' | head -1)

                    echo "  📦 $parent_name"

                    # Get incrementals for this parent
                    incrementals_list=$(find "$ext_dir" -maxdepth 1 -name "incremental_${parent_date}_*" -type d 2>/dev/null | sort)

                    if [[ -z "$incrementals_list" ]]; then
                        echo "    └─ (no incrementals - can be cleaned up)"
                    else
                        # Display each incremental
                        while IFS= read -r incremental; do
                            if [[ -n "$incremental" ]]; then
                                incr_name=$(basename "$incremental")
                                echo "    └─ 📄 $incr_name"
                            fi
                        done <<< "$incrementals_list"
                    fi
                fi
            done <<< "$parents_list"

            echo
        done
EOFSCRIPT
}

