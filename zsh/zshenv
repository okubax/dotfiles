# ~/.zshenv - environment variables, read by every zsh instance
# (login, interactive and scripts alike)

# XDG Base Directory Specification
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"

# Application homes
export ANDROID_HOME="$HOME/development/android/sdk"

# Default applications
export BROWSER="firefox"
export EDITOR="vim"
export TERMCMD="kitty"

# GUI/Display settings (prefer Wayland everywhere, X11 as fallback)
export QT_QPA_PLATFORM="wayland;xcb"
export QT_QPA_PLATFORMTHEME="qt5ct"
export ELECTRON_OZONE_PLATFORM_HINT="wayland"
export MOZ_ENABLE_WAYLAND=1
export GDK_BACKEND=wayland
export QEMU_AUDIO_DRV=pipewire
#export VK_DRIVER_FILES=""

# Secrets (API keys etc.) live in ~/.zshrc.local, which is sourced by
# ~/.zshrc and not tracked in this repo. Note: that means they're only
# set in interactive shells, not in scripts or apps launched outside one.

# Java options: keep _JAVA_OPTIONS unset (it makes the JVM print a noisy
# "Picked up _JAVA_OPTIONS" line) and pass the flags via a java alias instead
_JAVA_OPTIONS='-Dawt.useSystemAAFontSettings=on -Dswing.aatext=true -Dswing.defaultlaf=com.sun.java.swing.plaf.gtk.GTKLookAndFeel -Djdk.gtk.version=3'
_SILENT_JAVA_OPTIONS="$_JAVA_OPTIONS"
_JAVA_AWT_WM_NONREPARENTING=1
unset _JAVA_OPTIONS
alias java="java $_SILENT_JAVA_OPTIONS"

# PATH construction
path_dirs=(
    # User binaries
    "$HOME/bin"
    "$HOME/.cargo/bin"
    "$HOME/.npm-global/bin"
    "$HOME/.local/bin"
    
   # Android development
    "$HOME/development/android/sdk/cmdline-tools/12.0/bin"
    "$HOME/development/android/sdk/cmdline-tools/12.0"
    "$HOME/development/android/sdk/platform-tools"
    
    # Personal projects
    "$HOME/git/ii"
    "$HOME/git/nettop"
    "$HOME/git/2048.c"
    "$HOME/git/pass2csv"
    
    # Virtual environments
    "$HOME/venv/vizex/bin"
    
    # Other tools
    "$HOME/.firefox"
    "$HOME/machines/qemu-scripts"
)

# Append each directory to PATH, skipping ones that don't exist
for dir in "${path_dirs[@]}"; do
    [[ -d "$dir" ]] && PATH="$PATH:$dir"
done

export PATH
